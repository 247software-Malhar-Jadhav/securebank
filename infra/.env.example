# =============================================================================
# SecureBank — local environment knobs for docker-compose
# =============================================================================
# Copy to .env (which is gitignored) and adjust as needed:
#   cp .env.example .env
# All values have sensible defaults baked into docker-compose.yml, so an empty
# .env still works. Override only what you need.
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=securebank
POSTGRES_USER=securebank
POSTGRES_PASSWORD=securebank
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Kafka ----
KAFKA_PORT=9092
KAFKA_TOPIC_PARTITIONS=3

# ---- RabbitMQ ----
RABBITMQ_USER=securebank
RABBITMQ_PASSWORD=securebank
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ---- Backend ----
BACKEND_PORT=8080
# JWT signing secret — MUST be 32+ chars in any non-throwaway environment.
JWT_SECRET=change-me-please-use-a-32+char-secret-in-prod
# API key for the external AI/LLM provider (leave blank to use deterministic fallback).
AI_API_KEY=
# Virtual-thread scheduler parallelism (0 = JVM default = #CPUs).
VT_PARALLELISM=0

# ---- Frontend ----
FRONTEND_PORT=8081

# ---- Observability profile (only used with: --profile observability) ----
KAFKA_UI_PORT=8082
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
